# ── EchoCare Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to GitHub — it is already in .gitignore.

# No AI API key needed — EchoCare uses Pollinations.ai (free, no signup).

# Caregiver email for emergency and safe check-in alerts
VITE_CAREGIVER_EMAIL=caregiver@example.com
