# ── EchoCare Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to GitHub — it's already in .gitignore.

# Anthropic API key — get yours at https://console.anthropic.com
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Caregiver email address for emergency and safe check-in alerts
VITE_CAREGIVER_EMAIL=caregiver@example.com
